NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wework_saas
DB_USER=root
DB_PASSWORD=your_password

# --- 排障 ---
# 以下命令须在 backend 目录执行；或在仓库根目录用：npm run backend:dev:clean
# 1) 端口被占用: npm run kill:3000  或  npm run dev:clean
# 2) MySQL root 密码不对: 本机 brew 可先试「无密码」连接 mysql -u root
#    若仍失败，执行 mysql_secure_installation 或查阅 Homebrew MySQL 文档重置 root。
#    将能登录的账号密码写入 DB_USER / DB_PASSWORD，与 001_phase1_mvp.sql 导入的库一致。

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# 前端地址（CORS），多个用逗号分隔。开发环境下 localhost/127.0.0.1 的 5173–5179 会自动并入（Vite 占端口顺延）。
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8080

# 企微扫码登录（生产必填）：浏览器最终打开的前端站点根 URL（OAuth 成功后 302 到此域名的 /wework/callback）
# 示例：https://wework.syzs.top
FRONTEND_URL=http://localhost:5173

# 企微 OAuth「授权回调域」所指向的 API 根（不含路径）。实际回调地址 =
#   ${WEWORK_CALLBACK_URL}/api/v1/wework/callback
# 若 nginx 同域反代前后端，可与 FRONTEND_URL 同源；内网开发常为 http://127.0.0.1:3000
WEWORK_CALLBACK_URL=http://127.0.0.1:3000

# ---------- 生产：企微私域独立子域 wework.syzs.top（与其它 syzs 子域隔离）----------
# 本仓库为「企微私域 SaaS」，线上前端/API 回调建议只绑定 wework.syzs.top。
# 请勿把主域 syzs.top、https://ai.syzs.top/、https://crm.syzs.top/ 等写入本服务的 FRONTEND_ORIGIN / FRONTEND_URL，
# 除非刻意允许其它子域页面直接跨域调用本 API（一般不需要）。
# 示例（Nginx 同域反代 /api 时，三者可同为 wework）：
#   FRONTEND_ORIGIN=https://wework.syzs.top
#   FRONTEND_URL=https://wework.syzs.top
#   WEWORK_CALLBACK_URL=https://wework.syzs.top
#
# 广告监测 302 落地页白名单（逗号分隔）。勿填 apex「syzs.top」——代码会放行 *.syzs.top，从而误包含 ai/crm 等子域。
# 仅填精确子域即可，例如：
#   AD_REDIRECT_ALLOW_HOSTS=wework.syzs.top

# 每日凌晨 2 点（进程本地时区）自动同步企微客户；设为 0 关闭
ENABLE_SYNC_CRON=1

# 流程向客户直发企微消息：每租户每分钟上限（内存计数，多实例需自行换 Redis）
AUTO_SEND_RATE_LIMIT=10

# 群发：每分钟扫描 scheduled_at 已到且 status=scheduled 的任务并发送；生产按需设为 1
# ENABLE_BROADCAST_CRON=1

# ---------- 注册验证码（邮箱 / 短信）----------
# 设为 1 时：须先 POST /api/v1/auth/register/send-otp，注册体需带 register_channel、register_target、otp_code
# REGISTER_OTP_REQUIRED=1
# 生产仅手机号注册（不配置 SMTP 时可设 1，API 只返回 sms 渠道）
# REGISTER_OTP_SMS_ONLY=1
#
# 邮箱：配置 SMTP（与常见企业邮箱 / SendGrid 等兼容）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="企微SaaS <noreply@example.com>"
# REGISTER_OTP_MAIL_SUBJECT=企微私域 SaaS 注册验证码
#
# 短信：支持 阿里云SMS（优先级高）或自定义 Webhook
# 方案 1：阿里云 SMS（推荐）
# REGISTER_OTP_ALIYUN_KEY_ID=
# REGISTER_OTP_ALIYUN_KEY_SECRET=
# REGISTER_OTP_ALIYUN_SIGN_NAME=企微私域
# REGISTER_OTP_ALIYUN_TEMPLATE_CODE=SMS_123456789
#
# 方案 2：自定义 HTTP Webhook（本服务 POST JSON 到你的网关）
# SMS_WEBHOOK_URL=https://your-service.example.com/internal/send-sms
# SMS_WEBHOOK_AUTH=Bearer your_token

# ---------- 多平台广告转化回传（可选）----------
# 留资成功自动回传（默认开启；关闭：AD_CONVERSION_AUTO_ON_LEAD=0）
# AD_CONVERSION_AUTO_ON_LEAD=1
# 企微加好友自动回传（默认与留资一致；单独关闭：AD_CONVERSION_AUTO_ON_WEWORK_ADD=0）
# AD_CONVERSION_AUTO_ON_WEWORK_ADD=1
# 投流绑定活码 state：GET /api/v1/ads/wework-state?tenant_id=1&ad_hit=123 → { state: "zfah123" }
#
# 巨量 / 抖音：监测链 macro callback 即可 GET 回传；或接 API：
# OCEAN_ADS_ENABLED=1
# OCEAN_ADS_ACCESS_TOKEN=
# OCEAN_ADS_ENDPOINT=
#
# 百度 OCPC：
# BAIDU_ADS_ENABLED=1
# BAIDU_ADS_TOKEN=
# BAIDU_ADS_LOGID_URL_BASE=https://你的落地页域名
# BAIDU_ADS_ENDPOINT=https://ocpc.baidu.com/ocpcapi/api/uploadConvertData
#
# 小红书聚光（callback 或自定义 endpoint）：
# XHS_ADS_ENABLED=1
# XHS_ADS_ACCESS_TOKEN=
# XHS_ADS_ENDPOINT=
#
# 知乎效果营销：仅需监测链带回 __CALLBACK__，无需额外 env（见获客向导监测 URL）
#
# 支持平台列表（需登录）：GET /api/v1/ads/conversion/platforms
#
# ---------- 腾讯广告归因回传（可选）----------
# 启用后，POST /api/v1/ads/conversion 会尝试向腾讯广告回传 conversion。
# TENCENT_ADS_ENABLED=1
# TENCENT_ADS_ENDPOINT=https://api.e.qq.com/v1.3/attribution/conversion
# TENCENT_ADS_ACCESS_TOKEN=
# TENCENT_ADS_ACCOUNT_ID=
#
# 消耗同步（Marketing API daily_reports/get，金额「分」→ 库内「元」）
# 手动：POST /api/v1/ads/spend/sync/tencent （管理员 JWT）body: { start_date, end_date, granularity?: advertiser|campaign }
# 定时：需配置租户 ID（写入该租户 ad_spend_daily，platform=gdt）
# TENCENT_ADS_SPEND_SYNC_CRON=1
# TENCENT_ADS_SPEND_SYNC_TENANT_ID=1
# 默认 advertiser（账户按日汇总）；campaign=计划×日明细
# TENCENT_ADS_SPEND_SYNC_LEVEL=advertiser
# 新指标体系可尝试：TENCENT_ADS_ADQ_UPGRADE=1，若 cost 字段变化再用 TENCENT_ADS_COST_FIELD=stat_cost
# 同步逻辑会先试 REPORT_LEVEL_*，再自动试简写 level=ADVERTISER / CAMPAIGN（与官方示例 ADGROUP 风格一致）
# TENCENT_ADS_API_BASE=https://api.e.qq.com
# TENCENT_ADS_DAILY_REPORT_PATH=/v1.1/daily_reports/get

# ---------- P2：预聚合与后台任务队列（MySQL）----------
# 先执行 database/029_background_jobs.sql、030_agg_ads_roi_daily.sql、031_agg_channel_daily.sql、032_aggregation_meta.sql
# 读路径走日表（区间须已 rollup 且结束日早于「今天」，与实时写入避免竞态）：ROI 摘要/趋势、渠道报表
# AGG_READ=1
# 每分钟消费 background_jobs（rollup_ads_roi / rollup_channel / rollup_daily_batch）
# ENABLE_AGG_WORKER_CRON=1
# AGG_WORKER_BATCH=5
# 每日 01:15 入队「昨日」rollup_daily_batch（进程时区）
# ENABLE_AGG_NIGHTLY_CRON=1
# 队列概览（管理员 JWT）：GET /api/v1/ads/jobs/summary

# ---------- 裂变奖励异步发放队列（MySQL）----------
# 先执行 database/033_campaign_reward_jobs.sql
# 每分钟消费 campaign_reward_jobs（支持 scheduled_at 延迟发放 + 自动重试）
# ENABLE_CAMPAIGN_REWARD_CRON=1
# CAMPAIGN_REWARD_BATCH=10

# ---------- 企微 token 跨进程缓存（PM2 集群建议开启）----------
# 先执行 database/034_wework_tokens.sql
# getAccessToken 已使用 MySQL wework_tokens + GET_LOCK(tenant) 互斥刷新（提前 5 分钟续期）

# ---------- 高危操作审计日志（Week 2）----------
# 先执行 database/035_audit_logs.sql
# 当前覆盖：删客户、导出客户、广播发送触发、自动化规则启停

# ---------- RBAC：权限字典 + roles 扩展（Step 1–2）----------
# 1) database/036_rbac_permissions.sql（permissions 表 + roles/users 扩展）
# 2) database/037_rbac_seed_roles.sql（存储过程 create_default_roles_for_tenant + 全租户幂等补角色 + 销售补 ads:view + 验证 SQL）

# ---------- 意向预警 + 话术推送（AI 员工）----------
# 先执行 database/039_intent_alert.sql
# 收件箱：客户新消息后自动生成 AI 草稿（INBOX_AUTO_DRAFT=1 时默认延迟 30s，销售可先抢答；INBOX_AUTO_DRAFT_DELAY_SEC=0 立即）
# INBOX_AUTO_DRAFT=1
# INBOX_AUTO_DRAFT_DELAY_SEC=30
# 收件箱 FAQ 自动发送：租户在系统设置开启后，p0 低风险且置信≥75% 才自动回复；设 0 全平台禁用
# 首发推广建议显式关闭全站自动外发：INBOX_AI_AUTO_SEND=0
# INBOX_AI_AUTO_SEND=0
# AI 自动发送后企微提醒会话负责人（设 INBOX_AI_AUTO_SEND_NOTIFY=0 关闭）
# INBOX_AI_AUTO_SEND_DAILY_CAP=80
# INBOX_AI_AUTO_SEND_THREAD_DAILY_CAP=3
# 收件箱风控：LLM 结构化评估 intent/risk（需 API Key，INBOX_AI_RISK_LLM=1；未开则用规则）
# INBOX_AI_RISK_LLM=1
# 自动发送抽检入队比例（默认 0.1 = 10%）
# INBOX_AI_QA_SAMPLE_RATE=0.1
# 数据库：database/072…、073…、074…、075…、076…（见 docs/deploy/go-live-ai-inbox.md）
# 每 5 分钟处理 24 小时内 pending 预警，给销售 owner.wework_userid 推送提醒
ENABLE_INTENT_ALERT_CRON=1
# 计费用量每日同步（customers/seats）: 02:00
ENABLE_USAGE_SYNC_CRON=1
# 订阅到期处理与提醒: 09:00
ENABLE_SUBSCRIPTION_EXPIRY_CRON=1
# 每周一 09:30 向管理员推送「本周战果」企微消息
# ENABLE_WEEKLY_DIGEST_CRON=1
# 每日 09:00 向管理员推送「今日必做」企微摘要（仅有待办时）
# ENABLE_TODAY_ACTIONS_CRON=1
# 每日 18:00 向管理员推送「今日 AI 自动回复」摘要（当日有自动发送时）
# ENABLE_AI_AUTO_REPLY_DIGEST_CRON=1
# 每日 10:00 活跃/用量下降流失预警（需 tenant_churn_alerts 表）
# ENABLE_CHURN_ALERT_CRON=1
# 每日 08:30 平台运营日报（企微 → PLATFORM_ADMIN_USER_IDS）
# ENABLE_PLATFORM_OPS_DIGEST_CRON=1
# 每月 1 日 09:00 将上月支付对账 Excel 邮件至 PLATFORM_OPS_DIGEST_EMAILS / 超管邮箱
# ENABLE_PLATFORM_PAYMENT_RECONCILE_CRON=1
# 每日 23:55 落库当月 MRR 快照（订阅口径）
# ENABLE_PLATFORM_MRR_SNAPSHOT_CRON=1

# ---------- 支付宝当面付扫码（Phase 2）----------
# 生产暂时关闭支付宝（计费页隐藏、接口拒绝 alipay 下单）
# ALIPAY_DISABLED=1
# 本地联调：ALIPAY_MOCK=1，计费页可「模拟支付成功」
# ALIPAY_MOCK=1
# 沙箱：ALIPAY_SANDBOX=1（网关 openapi-sandbox.dl.alipaydev.com）
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=  # 应用私钥 PEM 或单行 base64（勿填支付宝公钥）
# ALIPAY_PUBLIC_KEY=   # 支付宝公钥 PEM（开放平台保存应用公钥后下载，勿填应用公钥）
# 或放文件：certs/alipay/app_private_key.pem + alipay_public_key.pem（见该目录 README）
# ALIPAY_PRIVATE_KEY_PATH=certs/alipay/app_private_key.pem
# ALIPAY_PUBLIC_KEY_PATH=certs/alipay/alipay_public_key.pem
# 密钥不匹配时：npm run verify:alipay
# ALIPAY_SKIP_SIGNATURE_VERIFY=0  # 仅开发

# ---------- 微信支付 Native 扫码（Phase 1）----------
# 本地联调（无需商户号）：WECHAT_PAY_MOCK=1，计费页可「模拟支付成功」
# WECHAT_PAY_MOCK=1
# 生产：商户平台申请后填写下列项；回调公网 HTTPS 根域（与 WEWORK_CALLBACK_URL 可同源）
# BILLING_NOTIFY_BASE_URL=https://wework.syzs.top
# 租户账单 PDF 中文字体（TTF/OTF）；不设则自动探测系统 Noto/宋体等，详见 backend/assets/fonts/README.md
# BILLING_PDF_FONT_PATH=/usr/share/fonts/truetype/noto/NotoSansSC-Regular.ttf
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
# 或 WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_PAY_PLATFORM_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# 仅开发可跳过通知 RSA 验签（生产务必配置平台证书并关闭此项）
# WECHAT_PAY_SKIP_SIGNATURE_VERIFY=0
# 公众号 JSAPI（与 WECHAT_PAY_APP_ID 同一应用）：在微信内打开计费页调起支付
# WECHAT_MP_APP_SECRET=
# 待支付订单超过 N 小时自动关闭（需 ENABLE_PAYMENT_EXPIRY_CRON=1）
# PAYMENT_PENDING_TTL_HOURS=24
# ENABLE_PAYMENT_EXPIRY_CRON=1

# 平台超管用户 ID（users.id，逗号分隔）：可确认全站收款、创建兑换码、直接开通套餐
# 查询：SELECT id, username, tenant_id FROM users WHERE role='admin' LIMIT 5;
PLATFORM_ADMIN_USER_IDS=
# 每日 08:30 平台运营日报推送到上述超管企微（超管须填 wework_userid）
# ENABLE_PLATFORM_OPS_DIGEST_CRON=1
# 每月 1 日 09:00 将上月支付对账 Excel 邮件至 PLATFORM_OPS_DIGEST_EMAILS / 超管邮箱
# ENABLE_PLATFORM_PAYMENT_RECONCILE_CRON=1
# 每日 23:55 落库当月 MRR 快照（订阅口径）
# ENABLE_PLATFORM_MRR_SNAPSHOT_CRON=1
# 日报企微消息从哪个租户的应用发出（须已配企微）；不设则用首个超管所属租户
# PLATFORM_DIGEST_TENANT_ID=1
# 日报邮件兜底（复用 SMTP_*）：超管 users.email + 下列额外邮箱
# PLATFORM_OPS_DIGEST_EMAILS=ops@yourcompany.com
# PLATFORM_OPS_DIGEST_EMAIL_ON_CRON=1
# 投递渠道：both（默认）| email_only（仅邮件，适合无企微）| wework_only
# PLATFORM_OPS_DIGEST_DELIVERY=email_only

# 与外部主站联通（可选，默认关闭；推荐使用站内 /app/ai-assistant）
# SYZS_PLATFORM_URL=
# SYZS_PLATFORM_JWT_SECRET=
ENABLE_GROUP_SOP_CRON=1
# 用于拼接企微消息中的客户详情链接：${APP_URL}/app/customers/:id
APP_URL=https://your-domain.com

# ---------- 腾讯云 TCCC 外呼 ----------
TCCC_MOCK=1
TCCC_SDK_APP_ID=
TCCC_SECRET_ID=
TCCC_SECRET_KEY=
TCCC_SERVER_NUMBER=
TCCC_CALLBACK_URL=https://your-domain.com/api/v1/callback/tccc
SMS_MOCK=1
ENABLE_SMS_CRON=1

# 平台合同附件存储目录（生产请挂载持久卷，默认 backend/data/contract-attachments）
# CONTRACT_UPLOAD_DIR=/var/lib/zhiflow/contract-attachments
