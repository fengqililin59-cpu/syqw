# 生产环境 backend/.env 模板（复制到 /var/www/wework-saas/backend/.env 后按需修改）
# 勿把含真实密钥的文件提交到 Git

NODE_ENV=production
PORT=3010

# ── MySQL（与服务器现有库一致；首次部署请用实际账号密码）──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wework_saas
DB_USER=你的数据库用户
DB_PASSWORD=你的数据库密码

# ── JWT（生产务必重新生成，勿用开发环境值）──
JWT_SECRET=请替换为64位以上随机串
JWT_EXPIRES_IN=7d

# ── 对外 URL（按你的域名修改）──
FRONTEND_URL=https://wework.syzs.top
FRONTEND_ORIGIN=https://wework.syzs.top
APP_URL=https://wework.syzs.top
WEWORK_CALLBACK_URL=https://wework.syzs.top

# ── 企微 / 业务 Cron（本轮迭代建议全开）──
AUTO_CREATE_CUSTOMER_ON_WEWORK_ADD=1
ENABLE_FLOW_ENGINE_CRON=1
ENABLE_AUTOMATION_CRON=1
ENABLE_FOLLOWUP_DUE_CRON=1
ENABLE_INBOX_SLA_CRON=1
ENABLE_TICKET_SLA_CRON=1

# ── 公域 Webhook Legacy Token（自建转发时用）──
PUBLIC_INBOX_WEBHOOK_SECRET=请替换为长随机串

# ── 健康巡检（可选，需租户已配企微）──
ENABLE_HEALTH_MONITOR_CRON=1
HEALTH_MONITOR_TENANT_ID=1
HEALTH_MONITOR_TOUSER=你的企微UserID
HEALTH_MONITOR_URL=http://127.0.0.1:3010

# ── 收件箱 SLA 阈值（分钟）──
INBOX_SLA_MINUTES=30

# ── AI / 短信 / TCCC 等：从旧 .env 保留或按需填写 ──
# DEEPSEEK_API_KEY=
# TCCC_MOCK=1
# SMS_MOCK=1
# ENABLE_SMS_CRON=1
